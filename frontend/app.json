{
  "expo": {
    "name": "Mis Finanzas Pro",
    "slug": "mis-finanzas-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mis-finanzas-pro",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.misfinanzas.pro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A14"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.misfinanzas.pro"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Mis Finanzas Pro",
      "shortName": "Finanzas Pro",
      "description": "Professional Finance & Payroll Manager",
      "backgroundColor": "#0A0A14",
      "themeColor": "#00D4AA"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A14"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
